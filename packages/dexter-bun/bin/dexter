#!/bin/sh
# Dexter Bun CLI entry point.

SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" 2>/dev/null && pwd)"
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *) SOURCE="$DIR/$TARGET" ;;
  esac
done

DIR="$(cd -P "$(dirname "$SOURCE")" 2>/dev/null && pwd)"

if command -v bun >/dev/null 2>&1; then
  BUN_BIN="$(command -v bun)"
elif [ -x "$HOME/.bun/bin/bun" ]; then
  BUN_BIN="$HOME/.bun/bin/bun"
else
  echo "dexter: bun is required but was not found on PATH or at \$HOME/.bun/bin/bun" >&2
  exit 127
fi

exec "$BUN_BIN" run "$DIR/../src/cli.ts" "$@"

{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-pre-bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-post-write"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-post-read"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-post-bash"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-stop"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-subagent-start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-subagent-stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=$HOME/.bun/bin:$PATH bun run $CLAUDE_PROJECT_DIR/meta/index.ts on-session-end"
          }
        ]
      }
    ]
  }
}

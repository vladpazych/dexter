#!/bin/sh
# Dexter Node CLI entry point.

SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" 2>/dev/null && pwd)"
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *) SOURCE="$DIR/$TARGET" ;;
  esac
done

DIR="$(cd -P "$(dirname "$SOURCE")" 2>/dev/null && pwd)"

if command -v node >/dev/null 2>&1; then
  NODE_BIN="$(command -v node)"
else
  echo "dexter: node is required but was not found on PATH" >&2
  exit 127
fi

exec "$NODE_BIN" --import jiti/register "$DIR/../src/cli.ts" "$@"
